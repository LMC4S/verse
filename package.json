{
  "name": "verse",
  "productName": "Verse",
  "version": "1.0.0",
  "description": "Speak. It becomes Verse. A menu bar voice transcription app for macOS.",
  "license": "AGPL-3.0-only",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "icon": "python3 scripts/make_icon.py",
    "tray-icons": "python3 scripts/make_tray_icons.py",
    "build": "electron-builder --mac dir",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "app.verse.transcriber",
    "productName": "Verse",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "Verse records audio to transcribe it."
      }
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/local_mlx_transcribe.py"
    ]
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1"
  }
}
