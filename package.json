{
  "name": "whisper-electron",
  "version": "0.1.19",
  "description": "A small desktop Whisper transcription app.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "icon": "python3 scripts/make_icon.py",
    "build": "electron-builder --mac dir",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "local.whisper.transcriber",
    "productName": "Whisper",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.icns"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/local_mlx_transcribe.py"
    ]
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1"
  }
}
